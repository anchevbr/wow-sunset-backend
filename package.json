{
  "name": "wow-sunset-backend",
  "version": "1.0.0",
  "description": "Backend API for sunset quality forecasting and historical analysis",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:smoke": "jest --runInBand src/api/__tests__/api.smoke.test.ts",
    "test:watch": "jest --watch"
