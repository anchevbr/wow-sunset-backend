# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# CORS — set to your frontend origin in production (e.g. https://myapp.com)
CORS_ORIGIN=*

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_ENABLED=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_PRIVATE_NETWORK=false

# Request body size limits
JSON_BODY_LIMIT=16kb
URL_ENCODED_BODY_LIMIT=16kb

# Cache TTLs (in seconds)
CACHE_TTL_GEOCODING=604800        # 7 days
CACHE_TTL_FORECAST=21600          # 6 hours
CACHE_TTL_HISTORICAL=2592000      # 30 days

# Coordinates precision for cache key normalization (decimal places)
COORDINATES_PRECISION=2

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000       # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Request Deduplication Lock TTL (seconds)
REQUEST_LOCK_TTL=30

# Internal ops endpoints
ENABLE_CACHE_STATS_ENDPOINT=false
